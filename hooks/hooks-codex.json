{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}/hooks/run-hook.cmd\" session-start-codex",
            "async": false
          },
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/apex-yagni-session-start.cjs\"",
            "async": false
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/apex-yagni-prompt-filter.cjs\"",
            "async": false
          }
        ]
      }
    ]
  }
}
